datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String
  name            String
  role            String        @default("SURVEILLANT") // ADMIN, SURVEILLANT, TECHNICIAN
  
  assignments     Assignment[]
  permanences     Permanence[]
  reclamationsCreated Reclamation[] @relation("CreatedBy")
  reclamationsAssigned Reclamation[] @relation("AssignedTo")
  activityLogs    ActivityLog[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Dortoir {
  id              String        @id @default(uuid())
  name            String        @unique // 1, 2, 3, 4, 5, 6, 7a, 7b, 8a, 8b
  assignments     Assignment[]
}

model Assignment {
  id              String        @id @default(uuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  dortoir         Dortoir?      @relation(fields: [dortoirId], references: [id])
  dortoirId       String?
  type            String        // ABSENCE, RESTAURANT, WEEKEND
  shift           String?       // MORNING, AFTERNOON, NIGHT
  date            DateTime
  
  absences        Absence[]
  restaurantLogs  RestaurantLog[]
  
  completed       Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model Absence {
  id              String        @id @default(uuid())
  assignment      Assignment    @relation(fields: [assignmentId], references: [id])
  assignmentId    String
  studentCount    Int
  absentCount     Int
  observations    String?
  date            DateTime      @default(now())
}

model RestaurantLog {
  id              String        @id @default(uuid())
  assignment      Assignment    @relation(fields: [assignmentId], references: [id])
  assignmentId    String
  type            String        // BREAKFAST, LUNCH, DINNER
  studentCount    Int
  observations    String?
  date            DateTime      @default(now())
}

model Reclamation {
  id              String            @id @default(uuid())
  title           String
  description     String
  status          String            @default("PENDING") // PENDING, IN_PROGRESS, DONE
  
  createdBy       User              @relation("CreatedBy", fields: [createdById], references: [id])
  createdById     String
  technician      User?             @relation("AssignedTo", fields: [technicianId], references: [id])
  technicianId    String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Permanence {
  id              String        @id @default(uuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  shift           String        // MORNING, AFTERNOON, NIGHT
  date            DateTime
  createdAt       DateTime      @default(now())
}

model ActivityLog {
  id              String        @id @default(uuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  action          String
  timestamp       DateTime      @default(now())
}
